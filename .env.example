# Influencer Discovery App Environment Configuration

# AI API Keys - Required for influencer analysis
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GROQ_API_KEY=your-groq-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Social Media API Keys - Optional but recommended for enhanced features
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here
TWITTER_API_KEY=your-twitter-api-key-here
TWITTER_API_SECRET=your-twitter-api-secret-here
TWITTER_ACCESS_TOKEN=your-twitter-access-token-here
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret-here

INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token-here
INSTAGRAM_CLIENT_ID=your-instagram-client-id-here
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret-here

YOUTUBE_API_KEY=your-youtube-api-key-here
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token-here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/influencer_discovery
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=influencer_discovery
DATABASE_USER=influencer_user
DATABASE_PASSWORD=your-database-password

# Redis Configuration (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Application Configuration
SECRET_KEY=your-secret-key-here-generate-a-strong-one
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Scraping Configuration
SCRAPING_RATE_LIMIT=1.0
SCRAPING_MAX_RETRIES=3
SCRAPING_TIMEOUT=30
SCRAPING_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Instagram Scraping (Optional - for authenticated scraping)
INSTAGRAM_USERNAME=your-instagram-username
INSTAGRAM_PASSWORD=your-instagram-password

# Background Task Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn-here
ANALYTICS_ENABLED=True

# File Storage (for profile images, etc.)
STORAGE_TYPE=local
STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_USE_TLS=True

# Security Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Feature Flags
ENABLE_REAL_TIME_SCRAPING=True
ENABLE_AI_ANALYSIS=True
ENABLE_BRAND_MATCHING=True
ENABLE_CAMPAIGN_MANAGEMENT=True
ENABLE_ANALYTICS_DASHBOARD=True
