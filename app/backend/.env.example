# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/sales_intelligence

# External API Keys for Data Enrichment
HUNTER_API_KEY=your_hunter_io_api_key_here
CLEARBIT_API_KEY=your_clearbit_api_key_here
NEWS_API_KEY=your_news_api_key_here
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# Authentication (for future implementation)
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis Configuration (for background jobs)
REDIS_URL=redis://localhost:6379/0

# Application Settings
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
HUNTER_RATE_LIMIT=300  # requests per hour
CLEARBIT_RATE_LIMIT=1000  # requests per hour
NEWS_API_RATE_LIMIT=500  # requests per day

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=csv

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173